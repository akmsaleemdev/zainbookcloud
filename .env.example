# Supabase (required for the app to run)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Master Admin email (used by src/lib/auth-constants.ts). Required in production.
# In development, defaults to zainbooksys@gmail.com if unset.
VITE_MASTER_ADMIN_EMAIL=zainbooksys@gmail.com
